menu "UWA Jetski — GPS (Neo-6M UART)"
    config GPS_UART_PORT_NUM
        int "UART port"
        range 0 2
        default 1

    config GPS_UART_RX_GPIO
        int "GPS RX GPIO (connect to module TX)"
        range 0 48
        default 18

    config GPS_UART_TX_GPIO
        int "GPS TX GPIO (connect to module RX, optional)"
        range 0 48
        default 17

    config GPS_UART_BAUD
        int "UART baud rate"
        default 9600
endmenu
