menu "UWA Jetski — GPS (Neo-6M UART)"
    config GPS_UART_PORT_NUM
        int "UART port"
        range 0 2
        default 1

    config GPS_UART_BAUD
        int "Baud rate"
        default 9600

    config GPS_UART_RX_GPIO
        int "MCU RX GPIO — connect to Neo-6M TX"
        range 0 48
        default 21

    config GPS_UART_TX_GPIO
        int "MCU TX GPIO to Neo-6M RX, or -1 if not wired"
        range -1 48
        default -1
endmenu
