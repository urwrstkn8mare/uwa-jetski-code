menu "UWA Jetski - Joystick potentiometers"

    comment "X axis (left/right)"

    config JOYSTICK_X_GPIO
        int "X pot ADC GPIO"
        range 1 48
        default 18

    config JOYSTICK_X_ADC_MIN
        int "X pot raw ADC at 0% (full left)"
        default 0

    config JOYSTICK_X_ADC_ZERO
        int "X pot raw ADC at 50% (centre)"
        default 2047
        help
            ADC reading when the stick is centred. Always maps to exactly 50%.
            The range below this scales to 0..50% and above scales to 50..100%,
            so an off-centre physical zero does not introduce a dead-band or offset.

    config JOYSTICK_X_ADC_MAX
        int "X pot raw ADC at 100% (full right)"
        default 4095

    comment "Y axis (up/down)"

    config JOYSTICK_Y_GPIO
        int "Y pot ADC GPIO"
        range 1 48
        default 19
        help
            Must be on the same ADC unit as the X pot GPIO.

    config JOYSTICK_Y_ADC_MIN
        int "Y pot raw ADC at 0% (full down)"
        default 0

    config JOYSTICK_Y_ADC_ZERO
        int "Y pot raw ADC at 50% (centre)"
        default 2047
        help
            ADC reading when the stick is centred. Always maps to exactly 50%.
            The range below this scales to 0..50% and above scales to 50..100%,
            so an off-centre physical zero does not introduce a dead-band or offset.

    config JOYSTICK_Y_ADC_MAX
        int "Y pot raw ADC at 100% (full up)"
        default 4095

endmenu
