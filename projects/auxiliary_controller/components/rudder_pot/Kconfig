menu "UWA Jetski — Rudder potentiometer"
    config POT_GPIO_NUM
        int "ADC GPIO (rudder pot wiper)"
        range 1 48
        default 18

    config POT_ADC_RAW_MIN
        int "Raw ADC at 0%%"
        default 0

    config POT_ADC_RAW_MAX
        int "Raw ADC at 100%%"
        default 4095
endmenu
