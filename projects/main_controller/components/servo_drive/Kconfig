menu "UWA Jetski — Rudder PWM (LEDC)"

    config SERVO_A_GPIO
        int "Channel A PWM GPIO"
        range 1 48
        default 1

    config SERVO_B_GPIO
        int "Channel B PWM GPIO"
        range 1 48
        default 2

    config SERVO_LEDC_TIMER_IDX
        int "LEDC timer index (0–3)"
        range 0 3
        default 0

    config SERVO_LEDC_CHANNEL_A
        int "LEDC channel A"
        range 0 7
        default 0

    config SERVO_LEDC_CHANNEL_B
        int "LEDC channel B"
        range 0 7
        default 1
endmenu
