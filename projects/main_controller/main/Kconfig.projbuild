menu "Main controller — servo PWM"
    config SERVO_A_GPIO
        int "Servo A (PWM) GPIO"
        range 1 48
        default 1
        help
            GPIO for first servo PWM (LEDC).

    config SERVO_B_GPIO
        int "Servo B (PWM) GPIO"
        range 1 48
        default 2
        help
            GPIO for second servo PWM (LEDC).

    config SERVO_LEDC_TIMER_IDX
        int "LEDC timer index (0–3)"
        range 0 3
        default 0

    config SERVO_LEDC_CHANNEL_A
        int "LEDC channel for servo A"
        range 0 7
        default 0

    config SERVO_LEDC_CHANNEL_B
        int "LEDC channel for servo B"
        range 0 7
        default 1
endmenu

menu "Main controller — ICM-20948 (I2C)"
    config ICM_I2C_PORT_NUM
        int "I2C port number"
        range 0 1
        default 0

    config ICM_I2C_SDA_GPIO
        int "I2C SDA GPIO"
        range 0 48
        default 43

    config ICM_I2C_SCL_GPIO
        int "I2C SCL GPIO"
        range 0 48
        default 44

    config ICM_I2C_ADDR_AD1
        bool "Use I2C address 0x69 (AD0 high)"
        default n
        help
            If n, address 0x68 is used (typical AD0 low).

endmenu
