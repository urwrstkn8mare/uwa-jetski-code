menu "Potentiometer Configuration"

    config POTENTIOMETER_GPIO
        int "Potentiometer GPIO pin number"
        range 0 53
        default 49
        help
            GPIO pin connected to the potentiometer.

    config POTENTIOMETER_MIN_VALUE
        int "Potentiometer raw ADC minimum"
        range 0 65535
        default 0
        help
            Raw ADC value corresponding to the physical minimum (0%% output).

    config POTENTIOMETER_MAX_VALUE
        int "Potentiometer raw ADC maximum"
        range 0 65535
        default 4095
        help
            Raw ADC value corresponding to the physical maximum (100%% output).

endmenu
