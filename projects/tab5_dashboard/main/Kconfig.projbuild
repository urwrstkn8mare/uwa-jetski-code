menu "UWA Jetski - Tab5 Dashboard"

choice TAB5_DASHBOARD_FEED_MODE
    prompt "Dashboard feed source"
    default TAB5_DASHBOARD_FEED_MODE_CAN

    config TAB5_DASHBOARD_FEED_MODE_CAN
        bool "CAN"

    config TAB5_DASHBOARD_FEED_MODE_DEMO
        bool "DEMO"
endchoice

config TAB5_DASHBOARD_DEMO_HZ
    int "DEMO update rate (Hz)"
    default 60
    range 1 200

endmenu

